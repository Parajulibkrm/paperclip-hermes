# Copy to .env (or paste these into Dokploy's env-var UI) and fill in the keys
# you actually use. Only one inference-provider key is strictly required —
# pick the one that matches HERMES_MODEL.

# ---- Model selection ----
# See hermes-config.yaml for examples. Default is openrouter/free.
HERMES_MODEL=openrouter/free

# ---- Inference providers ----
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ---- Browser providers (optional — local Chromium is bundled too) ----
BROWSER_USE_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ---- Paperclip web exposure ----
# Public hostname Traefik routes to this service. Required for Dokploy/Traefik.
# No scheme, no port. Example: paperclip.example.com
# Alias: IP_ADDRESS — same meaning (accepted for Dokploy setups that followed an older README).
# The Paperclip runtime reads hostname allowlists via PAPERCLIP_ALLOWED_HOSTNAMES /
# auth URL env (see README); entrypoint derives those from `PAPERCLIP_DOMAIN` automatically.
PAPERCLIP_DOMAIN=
IP_ADDRESS=

# Compose-friendly knob; entrypoint forwards it into Paperclip's
# PAPERCLIP_DEPLOYMENT_EXPOSURE env (upstream does not listen to `PAPERCLIP_EXPOSURE` alone).
#   public — recommended behind Traefik; entrypoint defaults PAPERCLIP_PUBLIC_URL to https://DOMAIN
#   private — hostname allowlist only; PAPERCLIP_DOMAIN is appended to PAPERCLIP_ALLOWED_HOSTNAMES
PAPERCLIP_EXPOSURE=public
# Explicit override optional (otherwise derived from `PAPERCLIP_EXPOSURE`):
PAPERCLIP_DEPLOYMENT_EXPOSURE=
#
# Overrides if you can't use HTTPS or need a non-default origin:
PAPERCLIP_PUBLIC_URL=
PAPERCLIP_ALLOWED_HOSTNAMES=

# Bind mode for paperclipai's reachability preset:
#   loopback — 127.0.0.1 only (paperclipai default — unreachable through Traefik)
#   lan      — all interfaces (the right choice for any networked deploy)
#   tailnet  — Tailscale-only
PAPERCLIP_BIND=lan
